#!/bin/sh

CERT_ENTRY="custom/my-root-ca.crt"

if [ -f /etc/ca-certificates.conf ]; then
	if ! grep -qxF "$CERT_ENTRY" /etc/ca-certificates.conf; then
		echo "$CERT_ENTRY" >> /etc/ca-certificates.conf
	fi
fi

if command -v update-ca-certificates >/dev/null 2>&1; then
	update-ca-certificates
fi

exit 0
